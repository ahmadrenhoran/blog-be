# 1. Gunakan base image yang stabil
FROM node:18-slim

# 2. Buat user baru (HF menyarankan tidak menggunakan root untuk keamanan)
RUN useradd -m -u 1000 user
USER user
ENV HOME=/home/user \
    PATH=/home/user/.local/bin:$PATH

# 3. Set working directory
WORKDIR $HOME/app

# 4. Copy file manifest dan install dependencies
COPY --chown=user package*.json ./
RUN npm install

# 5. Copy seluruh kode sumber
COPY --chown=user . .

# 6. Ekspos Port 7860 (Standar Hugging Face)
EXPOSE 7860

# 7. Jalankan aplikasi dengan environment port yang benar
ENV PORT=7860
CMD ["node", "src/index.js"]